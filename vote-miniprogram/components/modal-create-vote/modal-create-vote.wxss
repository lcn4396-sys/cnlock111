.modal-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-box { width: 600rpx; background: #fff; border-radius: 16rpx; padding: 32rpx; position: relative; z-index: 1001; }
.modal-title { font-size: 32rpx; margin-bottom: 24rpx; text-align: center; }
.modal-input { border: 1rpx solid #eee; padding: 24rpx; margin-bottom: 16rpx; border-radius: 8rpx; font-size: 28rpx; min-height: 88rpx; box-sizing: border-box; display: block; width: 100%; }
.modal-btn { margin-top: 24rpx; padding: 24rpx; background: #07c160; color: #fff; text-align: center; border-radius: 8rpx; }
