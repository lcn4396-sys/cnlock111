<view class="page">
  <view class="report-item" wx:for="{{list}}" wx:key="id">
    <view class="report-content">{{item.content}}</view>
    <view class="report-meta">
      <text class="report-type">类型 {{item.reportType}} · 目标 {{item.targetType}}#{{item.targetId}}</text>
      <text class="report-time">{{item.createTimeStr}}</text>
      <text class="report-status {{item.status === 1 ? 'done' : ''}}">{{item.status === 0 ? '待处理' : '已处理'}}</text>
    </view>
  </view>
  <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无举报记录</view>
  <view wx:if="{{loading}}" class="loading">加载中…</view>
</view>
