.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.report-item { background: #fff; padding: 24rpx; margin-bottom: 16rpx; border-radius: 12rpx; }
.report-content { font-size: 28rpx; color: #333; margin-bottom: 12rpx; }
.report-meta { font-size: 24rpx; color: #999; }
.report-time { margin-right: 16rpx; }
.report-status { color: #ee0a24; }
.report-status.done { color: #07c160; }
.empty { padding: 80rpx; text-align: center; color: #999; }
.loading { padding: 24rpx; text-align: center; color: #999; }
