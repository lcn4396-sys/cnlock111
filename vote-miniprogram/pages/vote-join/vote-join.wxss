.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.form { background: #fff; border-radius: 12rpx; padding: 24rpx; }
.head { margin-bottom: 24rpx; }
.cover { width: 100%; height: 300rpx; border-radius: 12rpx; background: #eee; margin-bottom: 16rpx; }
.title { font-size: 32rpx; }
.opt-title { margin-bottom: 16rpx; font-size: 28rpx; }
.opt-hint { font-size: 24rpx; color: #999; font-weight: normal; }
.option { display: flex; align-items: center; padding: 24rpx; min-height: 96rpx; box-sizing: border-box; border: 1rpx solid #eee; border-radius: 8rpx; margin-bottom: 16rpx; }
.option.active { border-color: #07c160; background: #f0fff4; }
.check { margin-right: 16rpx; }
.opt-text { flex: 1; }
.btn { margin-top: 32rpx; padding: 28rpx; min-height: 96rpx; display: flex; align-items: center; justify-content: center; background: #07c160; color: #fff; text-align: center; border-radius: 12rpx; font-size: 32rpx; box-sizing: border-box; }
