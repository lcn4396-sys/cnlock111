.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.form { background: #fff; border-radius: 12rpx; padding: 24rpx; }
.field { margin-bottom: 24rpx; }
.field-label { font-size: 28rpx; color: #333; margin-bottom: 12rpx; font-weight: 500; }
.field-label .required { color: #ee0a24; }
.field-hint { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.input { border: 1rpx solid #eee; padding: 20rpx; margin-bottom: 0; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.textarea { min-height: 160rpx; width: 100%; }
.time-row { margin-bottom: 16rpx; }
.time-label { font-size: 26rpx; color: #333; margin-bottom: 8rpx; font-weight: 500; }
.row { display: flex; gap: 16rpx; }
.half { flex: 1; }
.picker-half { flex: 1; min-height: 88rpx; }
.picker-touch { display: block; cursor: pointer; }
.picker-value { color: #333; min-height: 88rpx; box-sizing: border-box; display: flex; align-items: center; }
.picker-value.placeholder { color: #999; }
.opt-hint { margin-bottom: 12rpx; }
.limit-picker { display: block; margin-bottom: 8rpx; }
.limit-picker .picker-value { margin-bottom: 0; }
.cover-upload { padding: 20rpx; text-align: center; color: #07c160; font-size: 28rpx; border: 1rpx dashed #07c160; border-radius: 8rpx; }
.cover-upload.disabled { color: #999; border-color: #ddd; background: #f7f7f7; }
.cover-preview { width: 100%; height: 320rpx; margin-top: 16rpx; border-radius: 8rpx; background: #f2f2f2; }
.cover-remove { margin-top: 12rpx; font-size: 26rpx; color: #999; text-align: right; }
.option { display: flex; align-items: center; margin-bottom: 16rpx; gap: 12rpx; }
.option .input { margin-bottom: 0; flex: 1; min-width: 0; }
.radio { font-size: 28rpx; color: #666; min-width: 48rpx; flex-shrink: 0; }
.flex { flex: 1; }
.opt-del { flex-shrink: 0; font-size: 26rpx; color: #999; padding: 12rpx 16rpx; }
.add-opt { margin-top: 12rpx; padding: 20rpx; text-align: center; color: #07c160; font-size: 28rpx; border: 1rpx dashed #07c160; border-radius: 8rpx; }
.btn { margin-top: 32rpx; padding: 28rpx; background: #07c160; color: #fff; text-align: center; border-radius: 12rpx; font-size: 32rpx; }
