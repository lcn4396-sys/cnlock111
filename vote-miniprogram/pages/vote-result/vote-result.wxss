.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.result-head { background: #fff; padding: 24rpx; border-radius: 12rpx; margin-bottom: 16rpx; }
.cover { width: 100%; height: 240rpx; border-radius: 8rpx; background: #eee; }
.title { font-size: 32rpx; display: block; margin-top: 16rpx; }
.result-list { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; }
.result-item { padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.result-item:last-child { border-bottom: none; }
.opt-title { font-size: 28rpx; }
.opt-count { font-size: 26rpx; color: #07c160; margin-left: 16rpx; }
.btn { padding: 28rpx; background: #07c160; color: #fff; text-align: center; border-radius: 12rpx; }
