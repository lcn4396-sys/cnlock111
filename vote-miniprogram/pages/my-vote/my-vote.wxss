.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.tabs { display: flex; background: #fff; border-radius: 12rpx; margin-bottom: 24rpx; overflow: hidden; }
.tab { flex: 1; text-align: center; padding: 28rpx; font-size: 28rpx; color: #666; }
.tab.active { background: #07c160; color: #fff; font-weight: 500; }
.list { }
.empty { padding: 80rpx; text-align: center; color: #999; font-size: 28rpx; }
.loading { padding: 24rpx; text-align: center; color: #999; }
