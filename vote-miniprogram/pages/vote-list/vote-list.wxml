<view class="page">
  <view class="nav-back" bindtap="onBack">
    <text class="nav-back-icon">←</text>
    <text class="nav-back-text">返回</text>
  </view>
  <category-bar list="{{categoryList}}" selectedId="{{categoryId}}" bindselect="onCategorySelect" />
  <scroll-view scroll-y class="list-scroll" bindscrolltolower="loadMore">
    <vote-card wx:for="{{list}}" wx:key="id" item="{{item}}" bindtap="onCardTap" />
    <view wx:if="{{loading}}" class="loading">加载中...</view>
    <view wx:if="{{!loading && list.length === 0}}" class="empty">暂无投票</view>
  </scroll-view>
</view>
