.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; padding-bottom: 48rpx; }
.section { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 24rpx; }
.section-title { font-size: 30rpx; font-weight: 500; margin-bottom: 24rpx; color: #333; }
.field { margin-bottom: 24rpx; }
.label { font-size: 26rpx; color: #666; display: block; margin-bottom: 12rpx; }
.input { border: 1rpx solid #eee; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; }
.btn { margin-top: 16rpx; background: #07c160; color: #fff; font-size: 30rpx; }
.btn-secondary { background: #576b95; }
.loading { padding: 24rpx; text-align: center; color: #999; }
