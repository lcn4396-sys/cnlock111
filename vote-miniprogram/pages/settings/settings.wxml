<view class="page">
  <view class="section">
    <view class="section-title">个人资料</view>
    <view class="form">
      <view class="field">
        <text class="label">昵称</text>
        <input class="input" placeholder="请输入昵称" value="{{profile.nickname}}" maxlength="64" bindinput="onNicknameInput" />
      </view>
      <view class="field">
        <text class="label">头像链接</text>
        <input class="input" placeholder="头像 URL" value="{{profile.avatarUrl}}" bindinput="onAvatarInput" />
      </view>
      <view class="field">
        <text class="label">手机号</text>
        <input class="input" type="number" placeholder="请输入11位手机号" value="{{profile.mobile}}" maxlength="11" bindinput="onMobileInput" />
      </view>
      <view class="field">
        <text class="label">邮箱</text>
        <input class="input" placeholder="请输入邮箱" value="{{profile.email}}" maxlength="128" bindinput="onEmailInput" />
      </view>
      <view class="field">
        <text class="label">地址</text>
        <input class="input" placeholder="请输入地址" value="{{profile.address}}" maxlength="256" bindinput="onAddressInput" />
      </view>
      <button class="btn" bindtap="onSaveProfile">保存资料</button>
    </view>
  </view>
  <view class="section">
    <view class="section-title">修改密码</view>
    <view class="form">
      <view class="field">
        <text class="label">原密码</text>
        <input class="input" password placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onOldPwdInput" />
      </view>
      <view class="field">
        <text class="label">新密码</text>
        <input class="input" password placeholder="6-32位新密码" value="{{newPassword}}" bindinput="onNewPwdInput" />
      </view>
      <button class="btn btn-secondary" bindtap="onChangePassword">修改密码</button>
    </view>
  </view>
  <view wx:if="{{loading}}" class="loading">加载中…</view>
</view>
