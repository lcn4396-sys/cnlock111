<view class="page">
  <!-- 未登录：手机号登录为主，微信登录为备选 -->
  <view class="guest-card" wx:if="{{!loggedIn}}">
    <text class="guest-tip">登录后可使用「我的投票、评论、设置」等功能</text>
    <button class="btn-phone" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">手机号快捷登录</button>
    <view class="guest-btns">
      <button class="btn-login" bindtap="goLogin">微信一键登录</button>
    </view>
    <text class="guest-hint">首次使用手机号登录将自动完成注册</text>
  </view>
  <!-- 已登录：统计 + 菜单 + 退出 -->
  <block wx:if="{{loggedIn}}">
    <view class="header" wx:if="{{summary}}">
      <view class="summary-row">
        <view class="summary-item" bindtap="goMyVote">
          <text class="summary-num">{{summary.createdCount || 0}}</text>
          <text class="summary-label">创建的投票</text>
        </view>
        <view class="summary-item" bindtap="goMyVote">
          <text class="summary-num">{{summary.joinedCount || 0}}</text>
          <text class="summary-label">参与的投票</text>
        </view>
        <view class="summary-item" bindtap="goMyComment">
          <text class="summary-num">{{summary.commentCount || 0}}</text>
          <text class="summary-label">评论</text>
        </view>
        <view class="summary-item" bindtap="goMyReport">
          <text class="summary-num">{{summary.reportCount || 0}}</text>
          <text class="summary-label">举报</text>
        </view>
      </view>
    </view>
    <view class="menu-list">
      <view class="menu-item" bindtap="goMyVote">
        <image class="menu-icon" src="/images/icon-vote.svg" mode="aspectFit" />
        <text class="menu-text">我的投票</text>
        <image class="menu-arrow" src="/images/icon-arrow.svg" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="goMyComment">
        <image class="menu-icon" src="/images/icon-comment.svg" mode="aspectFit" />
        <text class="menu-text">我的评论</text>
        <image class="menu-arrow" src="/images/icon-arrow.svg" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="goMyReport">
        <image class="menu-icon" src="/images/icon-report.svg" mode="aspectFit" />
        <text class="menu-text">我的举报</text>
        <image class="menu-arrow" src="/images/icon-arrow.svg" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="goSettings">
        <image class="menu-icon" src="/images/icon-settings.svg" mode="aspectFit" />
        <text class="menu-text">我的设置</text>
        <image class="menu-arrow" src="/images/icon-arrow.svg" mode="aspectFit" />
      </view>
      <view class="menu-item" bindtap="logout">
        <image class="menu-icon" src="/images/icon-logout.svg" mode="aspectFit" />
        <text class="menu-text">退出登录</text>
        <image class="menu-arrow" src="/images/icon-arrow.svg" mode="aspectFit" />
      </view>
    </view>
  </block>
</view>
