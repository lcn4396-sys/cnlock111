.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
/* 未登录卡片 */
.guest-card { background: #fff; border-radius: 12rpx; padding: 48rpx 32rpx; margin-bottom: 24rpx; text-align: center; }
.guest-tip { display: block; font-size: 28rpx; color: #666; margin-bottom: 32rpx; line-height: 1.5; }
.btn-phone { width: 100%; height: 88rpx; line-height: 88rpx; font-size: 32rpx; border-radius: 8rpx; background: #07c160; color: #fff; border: none; margin-bottom: 24rpx; }
.guest-btns { display: flex; justify-content: center; gap: 24rpx; margin-bottom: 24rpx; }
.guest-btns .btn-login { flex: 1; max-width: 240rpx; height: 80rpx; line-height: 80rpx; font-size: 30rpx; border-radius: 8rpx; background: #07c160; color: #fff; border: none; }
.guest-hint { font-size: 24rpx; color: #999; }
.header { background: #fff; border-radius: 12rpx; padding: 32rpx; margin-bottom: 24rpx; }
.summary-row { display: flex; justify-content: space-around; text-align: center; }
.summary-item { }
.summary-num { display: block; font-size: 40rpx; font-weight: 600; color: #07c160; }
.summary-label { font-size: 24rpx; color: #999; }
.menu-list { background: #fff; border-radius: 12rpx; overflow: hidden; }
.menu-item { display: flex; align-items: center; padding: 32rpx 24rpx; border-bottom: 1rpx solid #f0f0f0; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { width: 40rpx; height: 40rpx; margin-right: 24rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-arrow { width: 24rpx; height: 24rpx; }
