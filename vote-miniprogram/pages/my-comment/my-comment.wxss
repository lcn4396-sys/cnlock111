.page { min-height: 100vh; background: #f5f5f5; padding: 24rpx; }
.comment-item { background: #fff; padding: 24rpx; margin-bottom: 16rpx; border-radius: 12rpx; }
.comment-content { font-size: 28rpx; color: #333; display: block; margin-bottom: 12rpx; }
.comment-meta { font-size: 24rpx; color: #999; }
.comment-time { margin-right: 24rpx; }
.empty { padding: 80rpx; text-align: center; color: #999; }
.loading { padding: 24rpx; text-align: center; color: #999; }
