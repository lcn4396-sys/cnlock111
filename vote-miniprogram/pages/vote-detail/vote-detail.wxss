.page { min-height: 100vh; background: #f5f5f5; padding-bottom: 40rpx; }
.detail-head { background: #fff; padding: 24rpx; margin-bottom: 16rpx; }
.cover { width: 100%; height: 320rpx; border-radius: 12rpx; background: #eee; }
.title { font-size: 34rpx; display: block; margin-top: 16rpx; }
.desc { font-size: 26rpx; color: #666; margin-top: 8rpx; display: block; }
.actions { display: flex; flex-wrap: wrap; padding: 16rpx; gap: 16rpx; }
.actions .btn { padding: 24rpx 36rpx; min-height: 88rpx; min-width: 160rpx; display: flex; align-items: center; justify-content: center; background: #07c160; color: #fff; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.section { padding: 24rpx 16rpx 8rpx; font-size: 28rpx; }
.comment-section { display: flex; align-items: center; justify-content: space-between; }
.comment-count { font-size: 24rpx; color: #999; }
.comment-input-wrap { display: flex; align-items: flex-end; gap: 16rpx; padding: 16rpx; background: #fff; margin-bottom: 16rpx; }
.comment-input { flex: 1; min-height: 72rpx; max-height: 200rpx; padding: 16rpx; border: 1rpx solid #eee; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.comment-send { padding: 16rpx 28rpx; background: #07c160; color: #fff; border-radius: 8rpx; font-size: 28rpx; }
.comment-send.disabled { background: #ccc; color: #fff; }
.comment-list { padding: 0 16rpx 24rpx; background: #fff; }
.empty { padding: 40rpx; text-align: center; color: #999; }

/* 举报弹窗 */
.report-mask { position: fixed; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; }
.report-modal { position: fixed; left: 10%; right: 10%; top: 30%; background: #fff; border-radius: 16rpx; padding: 32rpx; z-index: 1001; box-sizing: border-box; }
.report-modal-title { font-size: 32rpx; font-weight: 600; margin-bottom: 24rpx; }
.report-modal-input { width: 100%; min-height: 160rpx; padding: 20rpx; border: 1rpx solid #eee; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; }
.report-modal-actions { display: flex; justify-content: flex-end; gap: 24rpx; margin-top: 24rpx; }
.report-modal-btn { padding: 20rpx 36rpx; font-size: 28rpx; border-radius: 8rpx; }
.report-modal-btn.cancel { background: #f5f5f5; color: #666; }
.report-modal-btn.submit { background: #07c160; color: #fff; }
